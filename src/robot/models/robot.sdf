<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="my_robot">
    <pose>0 0 0 0 0 -1.5708</pose>

    <link name="base_link">
      <inertial>
        <pose>0.0784 -0.123 0.025 0 0 0</pose>
        <mass>6.0</mass>
        <inertia>
          <ixx>0.08</ixx>
          <iyy>0.10</iyy>
          <izz>0.12</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <pose>0.0784 -0.123 0.09 0 0 0</pose>
        <geometry>
          <box>
            <size>0.28 0.16 0.035</size>
          </box>
        </geometry>
      </collision>

      <visual name="base_visual">
        <geometry>
          <mesh><uri>file://meshes/base_link.STL</uri></mesh>
        </geometry>
      </visual>
    </link>

    <link name="wheel1">
      <pose>0.024194 -0.183 0.042737 1.5708 -0.7627 0</pose>
      <inertial>
        <mass>0.053</mass>
        <inertia>
          <ixx>1.4e-5</ixx><iyy>1.4e-5</iyy><izz>2.5e-5</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="wheel1_collision">
        <geometry><cylinder><radius>0.035</radius><length>0.022</length></cylinder></geometry>
        <surface><friction><ode><mu>8.0</mu><mu2>8.0</mu2></ode></friction></surface>
      </collision>
      <visual name="wheel1_visual">
        <geometry><mesh><uri>file://meshes/wheel1.STL</uri></mesh></geometry>
      </visual>
    </link>

    <joint name="wheel1_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1000000</lower><upper>1000000</upper><effort>100</effort><velocity>100</velocity></limit>
        <dynamics><damping>0.3</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <link name="wheel2">
      <pose>0.13264 -0.183 0.042737 -1.5708 0.8893 -3.1416</pose>
      <inertial>
        <mass>0.053</mass>
        <inertia>
          <ixx>1.4e-5</ixx><iyy>1.4e-5</iyy><izz>2.5e-5</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="wheel2_collision">
        <geometry><cylinder><radius>0.035</radius><length>0.022</length></cylinder></geometry>
        <surface><friction><ode><mu>8.0</mu><mu2>8.0</mu2></ode></friction></surface>
      </collision>
      <visual name="wheel2_visual">
        <geometry><mesh><uri>file://meshes/wheel2.STL</uri></mesh></geometry>
      </visual>
    </link>

    <joint name="wheel2_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel2</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1000000</lower><upper>1000000</upper><effort>100</effort><velocity>100</velocity></limit>
        <dynamics><damping>0.3</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <link name="wheel3">
      <pose>0.024194 -0.062995 0.042737 1.5708 -0.80752 0</pose>
      <inertial>
        <mass>0.053</mass>
        <inertia>
          <ixx>1.4e-5</ixx><iyy>1.4e-5</iyy><izz>2.5e-5</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="wheel3_collision">
        <geometry><cylinder><radius>0.035</radius><length>0.022</length></cylinder></geometry>
        <surface><friction><ode><mu>8.0</mu><mu2>8.0</mu2></ode></friction></surface>
      </collision>
      <visual name="wheel3_visual">
        <geometry><mesh><uri>file://meshes/wheel3.STL</uri></mesh></geometry>
      </visual>
    </link>

    <joint name="wheel3_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel3</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1000000</lower><upper>1000000</upper><effort>100</effort><velocity>100</velocity></limit>
        <dynamics><damping>0.3</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <link name="wheel4">
      <pose>0.13264 -0.062995 0.042737 -1.5708 -0.77947 3.1416</pose>
      <inertial>
        <mass>0.053</mass>
        <inertia>
          <ixx>1.4e-5</ixx><iyy>1.4e-5</iyy><izz>2.5e-5</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="wheel4_collision">
        <geometry><cylinder><radius>0.035</radius><length>0.022</length></cylinder></geometry>
        <surface><friction><ode><mu>8.0</mu><mu2>8.0</mu2></ode></friction></surface>
      </collision>
      <visual name="wheel4_visual">
        <geometry><mesh><uri>file://meshes/wheel4.STL</uri></mesh></geometry>
      </visual>
    </link>

    <joint name="wheel4_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel4</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1000000</lower><upper>1000000</upper><effort>100</effort><velocity>100</velocity></limit>
        <dynamics><damping>0.3</damping><friction>0.1</friction></dynamics>
      </axis>
    </joint>

    <link name="lidar_link">
      <pose>0.08 -0.123 0.20 0 0 0</pose>
      <sensor name="gpu_lidar" type="gpu_lidar">
        <topic>/scan</topic>
        <update_rate>10</update_rate>
        <visualize>true</visualize>
        <lidar>
          <scan><horizontal><samples>720</samples><resolution>1</resolution><min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan>
          <range><min>0.12</min><max>8.0</max><resolution>0.01</resolution></range>
        </lidar>
        <always_on>true</always_on>
      </sensor>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent>
      <child>lidar_link</child>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>wheel1_joint</left_joint>
      <left_joint>wheel3_joint</left_joint>
      <right_joint>wheel2_joint</right_joint>
      <right_joint>wheel4_joint</right_joint>
      <wheel_separation>0.366</wheel_separation>
      <wheel_radius>0.035</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
      <max_linear_acceleration>0.4</max_linear_acceleration>
      <max_angular_acceleration>0.6</max_angular_acceleration>
    </plugin>

  </model>
</sdf>
