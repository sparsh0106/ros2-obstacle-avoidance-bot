<?xml version="1.0" encoding="utf-8"?>
<robot name="robot">

  <!-- ── Dummy root link ────────────────────────────────────────────────
       KDL (used by robot_state_publisher) does not support inertia on the
       root link and prints a warning if it finds one.  The fix is a
       massless, geometry-less base_footprint as the true root, joined to
       base_link with a fixed joint.  This is standard ROS convention.
  ──────────────────────────────────────────────────────────────────────── -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- BASE LINK -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0784152670222775 0.094776716004553 0.045" rpy="0 0 0" />
      <mass value="4" />
      <inertia ixx="0.00831118932493888"
               ixy="1.02401627657194E-19"
               ixz="5.57188860615719E-19"
               iyy="0.0201894602199616"
               iyz="-1.45311410016371E-19"
               izz="0.021267894957894" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="model://robot/meshes/base_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.08 0.09 0.045" rpy="0 0 0" />
      <geometry>
        <box size="0.30 0.15 0.06" />
      </geometry>
    </collision>
  </link>

  <!-- WHEEL 1 (Left Front) -->
  <link name="wheel1">
    <inertial>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <mass value="0.0530143760293277" />
      <inertia ixx="1.44408951371554E-05" ixy="0" ixz="0"
               iyy="1.44408951371554E-05" iyz="0"
               izz="2.53474985390223E-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="model://robot/meshes/wheel1.STL" />
      </geometry>
        <material>
	    <ambient>1 0 0 1</ambient>
	    <diffuse>1 0 0 1</diffuse>
	    <specular>0.2 0.2 0.2 1</specular>
  </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.02" />
      </geometry>
    </collision>
  </link>
  <joint name="wheel1_joint" type="continuous">
    <origin xyz="0.024194  0.183 0.042737" rpy="1.5708 -0.7627 0" />
    <parent link="base_link" />
    <child  link="wheel1" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.1" friction="0.0" />
  </joint>

  <!-- WHEEL 2 (Right Front) -->
  <link name="wheel2">
    <inertial>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <mass value="0.0530143760293277" />
      <inertia ixx="1.44408951371554E-05" ixy="0" ixz="0"
               iyy="1.44408951371554E-05" iyz="0"
               izz="2.53474985390223E-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="model://robot/meshes/wheel2.STL" />
      </geometry>
        <material>
    <ambient>0 1 0 1</ambient>
    <diffuse>0 1 0 1</diffuse>
    <specular>0.2 0.2 0.2 1</specular>
  </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.02" />
      </geometry>
    </collision>
  </link>
  <joint name="wheel2_joint" type="continuous">
    <origin xyz="0.13264 -0.183 0.042737" rpy="-1.5708 0.8893 -3.1416" />
    <parent link="base_link" />
    <child  link="wheel2" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.1" friction="0.0" />
  </joint>

  <!-- WHEEL 3 (Left Rear) -->
  <link name="wheel3">
    <inertial>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <mass value="0.0530143760293278" />
      <inertia ixx="1.44408951371554E-05" ixy="0" ixz="0"
               iyy="1.44408951371554E-05" iyz="0"
               izz="2.53474985390223E-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="model://robot/meshes/wheel3.STL" />
      </geometry>
        <material>
    <ambient>0 0 1 1</ambient>
    <diffuse>0 0 1 1</diffuse>
    <specular>0.2 0.2 0.2 1</specular>
  </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.02" />
      </geometry>
    </collision>
  </link>
  <joint name="wheel3_joint" type="continuous">
    <origin xyz="0.024194  0.062995 0.042737" rpy="1.5708 -0.80752 0" />
    <parent link="base_link" />
    <child  link="wheel3" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.1" friction="0.0" />
  </joint>

  <!-- WHEEL 4 (Right Rear) -->
  <link name="wheel4">
    <inertial>
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <mass value="0.0530143760293278" />
      <inertia ixx="1.44408951371554E-05" ixy="0" ixz="0"
               iyy="1.44408951371554E-05" iyz="0"
               izz="2.53474985390223E-05" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="model://robot/meshes/wheel4.STL" />
      </geometry>
        <material>
    <ambient>1 1 0 1</ambient>
    <diffuse>1 1 0 1</diffuse>
    <specular>0.2 0.2 0.2 1</specular>
  </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.02" />
      </geometry>
    </collision>
  </link>
  <joint name="wheel4_joint" type="continuous">
    <origin xyz="0.13264 -0.062995 0.042737" rpy="-1.5708 -0.77947 3.1416" />
    <parent link="base_link" />
    <child  link="wheel4" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.1" friction="0.0" />
  </joint>

  <!-- LIDAR LINK -->
  <link name="lidar_link">
    <inertial>
      <mass value="0.05" />
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.04" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.04" />
      </geometry>
    </collision>
  </link>
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.08 0 0.15" rpy="0 0 0" />
    <parent link="base_link" />
    <child  link="lidar_link" />
  </joint>

  <!-- ================= GAZEBO EXTENSIONS ================= -->

  <gazebo reference="wheel1">
    <mu1>1.0</mu1><mu2>1.0</mu2><kp>100000.0</kp><kd>1.0</kd>
  </gazebo>
  <gazebo reference="wheel2">
    <mu1>1.0</mu1><mu2>1.0</mu2><kp>100000.0</kp><kd>1.0</kd>
  </gazebo>
  <gazebo reference="wheel3">
    <mu1>1.0</mu1><mu2>1.0</mu2><kp>100000.0</kp><kd>1.0</kd>
  </gazebo>
  <gazebo reference="wheel4">
    <mu1>1.0</mu1><mu2>1.0</mu2><kp>100000.0</kp><kd>1.0</kd>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>wheel1_joint</left_joint>
      <left_joint>wheel3_joint</left_joint>
      <right_joint>wheel2_joint</right_joint>
      <right_joint>wheel4_joint</right_joint>
      <wheel_separation>0.366</wheel_separation>
      <wheel_radius>0.03</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <topic>/scan</topic>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <always_on>true</always_on>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>

</robot>
